@model PerryHomesTracker.Models.Home
@{
    ViewData["Title"] = "Home details";
}

<h1>Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.AddressLine1)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AddressLine1)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.AddressLine2)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.AddressLine2)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.City)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.City)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.State)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.State)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Zip)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Zip)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.CommunityName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.CommunityName)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.PlanName)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.PlanName)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Stage)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Stage!.Name)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.PrimaryContact)</dt>
        <dd class="col-sm-10">
            @if (Model.PrimaryContact != null)
            {
                @($"{Model.PrimaryContact.LastName}, {Model.PrimaryContact.FirstName}")
            }
            else
            {
                <span class="text-muted">—</span>
            }
        </dd>
    </dl>
    @if (Model.PurchaseInfo is { } purchase)
    {
        <h4 class="mt-4">Purchase</h4>
        <dl class="row">
            <dt class="col-sm-2">@Html.DisplayNameFor(model => purchase.ContractDate)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(_ => purchase.ContractDate)</dd>
            <dt class="col-sm-2">@Html.DisplayNameFor(model => purchase.ClosingDate)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(_ => purchase.ClosingDate)</dd>
            <dt class="col-sm-2">@Html.DisplayNameFor(model => purchase.PurchasePrice)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(_ => purchase.PurchasePrice)</dd>
        </dl>
    }
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
