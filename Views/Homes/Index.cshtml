@model IEnumerable<PerryHomesTracker.Models.Home>
@{
    ViewData["Title"] = "Homes";
}

<h1>Homes</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Address</th>
            <th>City</th>
            <th>Stage</th>
            <th>Primary contact</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.AddressLine1)</td>
            <td>@Html.DisplayFor(modelItem => item.City)</td>
            <td>@Html.DisplayFor(modelItem => item.Stage!.Name)</td>
            <td>
                @if (item.PrimaryContact != null)
                {
                    @($"{item.PrimaryContact.LastName}, {item.PrimaryContact.FirstName}")
                }
                else
                {
                    <span class="text-muted">—</span>
                }
            </td>
            <td class="text-nowrap">
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
