@model PerryHomesTracker.Models.Home
@{
    ViewData["Title"] = "Delete home";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Model?.FullAddress</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Stage)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Stage!.Name)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
